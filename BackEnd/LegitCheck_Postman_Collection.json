              "mode": "raw",
              "raw": "{\n    \"login\": \"admin\",\n    \"password\": \"admin_password\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://127.0.0.1:8000/api/login/",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["api", "login", ""]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Token <your_token_here>",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://127.0.0.1:8000/api/logout/",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["api", "logout", ""]
            }
          }
        }
      ]
    },
